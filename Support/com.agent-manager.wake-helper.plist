<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- The SMAppService flavor of the wake helper: shipped inside
     AgentManager.app/Contents/Library/LaunchDaemons and registered by the app
     ("Wake Mac for pings" toggle) with a one-time System Settings approval;
     no sudo. BundleProgram is resolved relative to the bundle root by launchd.
     No workspace argument here: the plist is sealed into the signed bundle, so
     it can't be personalized per user; the helper instead discovers every
     standard workspace under /Users/* and obeys each one's wake.json. -->
<dict>
	<key>Label</key>
	<string>com.agent-manager.wake-helper</string>
	<key>BundleProgram</key>
	<string>Contents/MacOS/am-wake-helper</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ProcessType</key>
	<string>Background</string>
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>com.agent-manager.app</string>
	</array>
</dict>
</plist>
